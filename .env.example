# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real credentials.

DATABASE_URL=postgres://mcp_watch:devpassword@localhost:5432/mcp_schema_watch
REDIS_HOST=localhost
REDIS_PORT=6379
PORT=3000

# Optional: fallback Slack webhook used when a watched server doesn't have
# its own slackWebhookUrl set. Get one from https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
